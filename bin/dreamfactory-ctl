#!/usr/bin/env bash
#
# dreamfactory — DreamFactory Quickstart CLI
#
# Usage:
#   dreamfactory serve [--port PORT]     Start the API server
#   dreamfactory setup                   Run first-time setup interactively
#   dreamfactory doctor                  Check binary runtime readiness
#   dreamfactory version                 Print package version metadata
#   dreamfactory login                   Login and print session JSON
#   dreamfactory demo pgsql              Create and register a PostgreSQL demo
#   dreamfactory demo sqlite             Create and register a local SQLite demo
#   dreamfactory service supported-types List quickstart-supported service types
#   dreamfactory service list-types      List available service types
#   dreamfactory service plan TYPE       Print a service payload template
#   dreamfactory service apply --file F  Create a service from JSON
#   dreamfactory service inspect NAME    Inspect service metadata
#   dreamfactory reset-admin             Create or reset the admin user
#   dreamfactory ai spec                 Print machine-readable AI helper spec
#   dreamfactory migrate                 Run database migrations
#   dreamfactory artisan [...]           Run any artisan command
#
# Environment:
#   DREAMFACTORY_STORAGE  Persistent data directory (default: ~/.dreamfactory)
#   ADMIN_EMAIL           Admin email for first-run setup
#   ADMIN_PASSWORD        Admin password for first-run setup (min 16 chars)
#   LISTEN_HOST           Host to bind (default: 0.0.0.0)
#   SERVER_PORT           Port to listen on (default: 8080)
#   DREAMFACTORY_URL      API URL for CLI calls (default: http://localhost:8080/api/v2)
#   DREAMFACTORY_SESSION_TOKEN  Session token for authenticated CLI calls

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# The frankenphp binary, when a command needs the embedded app runtime.
FRANKENPHP=""
if [ -x "$SCRIPT_DIR/frankenphp" ]; then
  FRANKENPHP="$SCRIPT_DIR/frankenphp"
elif command -v frankenphp &>/dev/null; then
  FRANKENPHP="frankenphp"
else
  # We might be running inside the embedded binary itself
  FRANKENPHP="$(cd "$(dirname "$0")/.." && pwd)/frankenphp"
  if [ ! -x "$FRANKENPHP" ]; then
    FRANKENPHP=""
  fi
fi

STORAGE="${DREAMFACTORY_STORAGE:-$HOME/.dreamfactory}"
export LARAVEL_STORAGE_PATH="$STORAGE"

configure_bundled_odbc() {
  local odbc_dir="$SCRIPT_DIR/odbc"
  local driver_path
  driver_path="$(find "$odbc_dir/microsoft/msodbcsql18/lib64" -maxdepth 1 -name 'libmsodbcsql-*.so*' -type f 2>/dev/null | sort | tail -1 || true)"

  if [ -n "$driver_path" ]; then
    export LD_LIBRARY_PATH="$odbc_dir/lib:$odbc_dir/microsoft/msodbcsql18/lib64:${LD_LIBRARY_PATH:-}"
    export ODBCSYSINI="$STORAGE/odbc"
    export ODBCINI="$STORAGE/odbc/odbc.ini"
    mkdir -p "$STORAGE/odbc"
    cat > "$STORAGE/odbc/odbcinst.ini" <<ODBC
[ODBC Driver 18 for SQL Server]
Description=Microsoft ODBC Driver 18 for SQL Server
Driver=$driver_path
UsageCount=1
ODBC
    [ -f "$STORAGE/odbc/odbc.ini" ] || : > "$STORAGE/odbc/odbc.ini"
  fi
}

configure_bundled_odbc

require_frankenphp() {
  if [ -z "$FRANKENPHP" ]; then
    echo "Error: frankenphp binary not found" >&2
    return 1
  fi
  if [ ! -x "$FRANKENPHP" ] && ! command -v "$FRANKENPHP" >/dev/null 2>&1; then
    echo "Error: frankenphp binary not found" >&2
    return 1
  fi
}

init_storage() {
  if [ ! -d "$STORAGE" ]; then
    echo "Initializing storage at $STORAGE ..."
  fi

  mkdir -p "$STORAGE/databases" \
           "$STORAGE/app" \
           "$STORAGE/framework/cache/data" \
           "$STORAGE/framework/sessions" \
           "$STORAGE/framework/views" \
           "$STORAGE/logs" \
           "$STORAGE/odbc"

  if [ ! -f "$STORAGE/databases/database.sqlite" ]; then
    touch "$STORAGE/databases/database.sqlite"
  fi
}

needs_setup() {
  [ ! -f "$STORAGE/.initialized" ]
}

admin_email() {
  printf '%s' "${ADMIN_EMAIL:-}"
}

admin_password() {
  printf '%s' "${ADMIN_PASSWORD:-}"
}

ensure_admin() {
  local email="$1"
  local password="$2"

  if [ -z "$email" ] || [ -z "$password" ]; then
    echo "Admin email and password are required." >&2
    return 1
  fi

  ADMIN_EMAIL="$email" ADMIN_PASSWORD="$password" $FRANKENPHP php-cli artisan tinker --execute='
    $email = getenv("ADMIN_EMAIL") ?: "";
    $password = getenv("ADMIN_PASSWORD") ?: "";
    if ($email === "" || $password === "") {
      fwrite(STDERR, "Admin email and password are required.\n");
      exit(1);
    }
    if (!\Schema::hasTable("user")) {
      fwrite(STDERR, "User table is missing. Run migrations/setup first.\n");
      exit(1);
    }
    $user = \DreamFactory\Core\Models\User::where("email", $email)->first();
    if ($user) {
      $user->password = $password;
      $user->is_sys_admin = true;
      $user->is_active = true;
      $user->save();
      echo "Admin ready.";
    } else {
      \DB::table("user")->insert([
        "name" => trim((getenv("ADMIN_FIRST_NAME") ?: "Admin") . " " . (getenv("ADMIN_LAST_NAME") ?: "User")),
        "first_name" => getenv("ADMIN_FIRST_NAME") ?: "Admin",
        "last_name" => getenv("ADMIN_LAST_NAME") ?: "User",
        "email" => $email,
        "username" => $email,
        "password" => \Hash::make($password),
        "is_sys_admin" => true,
        "is_active" => true,
        "phone" => getenv("ADMIN_PHONE") ?: "5555555555",
        "created_date" => now(),
        "last_modified_date" => now()
      ]);
      echo "Admin inserted.";
    }
  '
}

admin_exists() {
  local count
  count="$($FRANKENPHP php-cli artisan tinker --execute='
    echo \Schema::hasTable("user") ? \DB::table("user")->where("is_sys_admin", 1)->where("is_active", 1)->count() : 0;
  ' 2>/dev/null || true)"
  [ "${count##*$'\n'}" != "0" ]
}

write_caddyfile() {
  local host="$1"
  local port="$2"
  local caddyfile="$STORAGE/Caddyfile"
  local listen="$host:$port"

  if [ "$host" = "0.0.0.0" ]; then
    listen=":$port"
  fi

  cat > "$caddyfile" <<CADDY
{
	frankenphp
	order php_server before file_server
	admin off
}

$listen {
	root * public
	encode zstd gzip

	redir / /dreamfactory/dist/index.html 302
	redir /dreamfactory /dreamfactory/dist/index.html 302
	redir /dreamfactory/ /dreamfactory/dist/index.html 302
	redir /dreamfactory/dist /dreamfactory/dist/index.html 302
	redir /dreamfactory/dist/ /dreamfactory/dist/index.html 302

	php_server {
		resolve_root_symlink
	}
}
CADDY

  printf '%s' "$caddyfile"
}

run_setup() {
  require_frankenphp
  init_storage

  local email="${ADMIN_EMAIL:-}"
  local password="${ADMIN_PASSWORD:-}"
  local non_interactive="${NON_INTERACTIVE_SETUP:-false}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --admin-email|--email) email="$2"; shift 2 ;;
      --admin-email=*|--email=*) email="${1#*=}"; shift ;;
      --admin-password|--password) password="$2"; shift 2 ;;
      --admin-password=*|--password=*) password="${1#*=}"; shift ;;
      --non-interactive) non_interactive="true"; shift ;;
      *) shift ;;
    esac
  done

  echo "============================================"
  echo "  DreamFactory Quickstart — First-Time Setup"
  echo "============================================"
  echo ""

  # Generate APP_KEY if not set
  echo "Generating application key..."
  $FRANKENPHP php-cli artisan key:generate --force 2>/dev/null || true

  # Run migrations
  echo "Running database migrations..."
  $FRANKENPHP php-cli artisan migrate --force --seed 2>&1 | tail -5

  # Run DF setup
  echo "Configuring DreamFactory..."
  $FRANKENPHP php-cli artisan df:setup --force 2>/dev/null || true

  # Create admin user
  if [ -z "$email" ]; then
    if [ "$non_interactive" = "true" ]; then
      echo "Admin email is required. Pass --admin-email or set ADMIN_EMAIL." >&2
      return 1
    fi
    read -rp "Admin email: " email
  fi
  if [ -z "$password" ]; then
    if [ "$non_interactive" = "true" ]; then
      echo "Admin password is required. Pass --admin-password or set ADMIN_PASSWORD." >&2
      return 1
    fi
    read -rsp "Admin password (min 16 chars): " password
    echo ""
  fi

  if [ -n "$email" ] && [ -n "$password" ]; then
    $FRANKENPHP php-cli artisan df:setup \
      --admin_email "$email" \
      --admin_password "$password" \
      --admin_first_name "${ADMIN_FIRST_NAME:-Admin}" \
      --admin_last_name "${ADMIN_LAST_NAME:-User}" \
      --admin_phone "${ADMIN_PHONE:-5555555555}" \
      --force 2>&1 | grep -v "password" || true

    # df:setup can return successfully without creating the admin user in the
    # embedded binary runtime. Ensure the account exists before marking setup.
    ensure_admin "$email" "$password"
  fi

  # Clean up service types not in the quickstart profile.
  $FRANKENPHP php-cli artisan tinker --execute='
    if(\Schema::hasTable("service_type")){
      $remove = ["alloydb","cache_local","cache_memcached","cache_redis","ftp_file","local_file","sftp_file","webdav_file"];
      $count = \DB::table("service_type")->whereIn("name", $remove)->delete();
      echo "Cleaned $count unused service types.";
    }
  ' 2>/dev/null || true

  # Seed CORS
  $FRANKENPHP php-cli artisan tinker --execute='
    if(\Schema::hasTable("cors_config") && \DB::table("cors_config")->count() === 0){
      \DB::table("cors_config")->insert(["path"=>"*","origin"=>"*","header"=>"*","method"=>"*","max_age"=>0,"supports_credentials"=>false,"enabled"=>true]);
      echo "CORS config seeded.";
    }
  ' 2>/dev/null || true

  if ! admin_exists; then
    echo "Setup did not create an active system admin." >&2
    return 1
  fi

  touch "$STORAGE/.initialized"
  echo ""
  echo "Setup complete!"
}

cmd_serve() {
  require_frankenphp
  local port="${SERVER_PORT:-8080}"
  local host="${LISTEN_HOST:-0.0.0.0}"
  local setup_args=()

  # Parse --port flag
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --host) host="$2"; shift 2 ;;
      --host=*) host="${1#*=}"; shift ;;
      --port) port="$2"; shift 2 ;;
      --port=*) port="${1#*=}"; shift ;;
      --admin-email|--email)
        setup_args+=("--admin-email" "$2")
        shift 2
        ;;
      --admin-email=*|--email=*)
        setup_args+=("--admin-email" "${1#*=}")
        shift
        ;;
      --admin-password|--password)
        setup_args+=("--admin-password" "$2")
        shift 2
        ;;
      --admin-password=*|--password=*)
        setup_args+=("--admin-password" "${1#*=}")
        shift
        ;;
      --non-interactive)
        setup_args+=("--non-interactive")
        shift
        ;;
      *) shift ;;
    esac
  done

  init_storage

  if needs_setup; then
    run_setup "${setup_args[@]}"
  fi

  echo ""
  echo "============================================"
  echo "  DreamFactory Quickstart"
  echo "  Admin UI: http://localhost:$port/"
  echo "  API:      http://localhost:$port/api/v2"
  echo "  Listen:   http://$host:$port"
  echo "  Storage:  $STORAGE"
  echo "============================================"
  echo ""

  # FrankenPHP cd's into the embedded app dir at startup, so relative Caddy
  # roots point to the Laravel app within the embed.
  exec $FRANKENPHP run --config "$(write_caddyfile "$host" "$port")"
}

cmd_artisan() {
  require_frankenphp
  init_storage
  exec $FRANKENPHP php-cli artisan "$@"
}

cmd_doctor() {
  require_frankenphp
  init_storage
  local failures=0

  check() {
    local name="$1"
    shift
    if "$@" >/dev/null 2>&1; then
      printf 'ok   %s\n' "$name"
    else
      printf 'fail %s\n' "$name"
      failures=$((failures + 1))
    fi
  }

  check "frankenphp binary" "$FRANKENPHP" version
  check "embedded Laravel app" "$FRANKENPHP" php-cli artisan --version
  check "storage writable" test -w "$STORAGE"
  check "sqlite database" test -f "$STORAGE/databases/database.sqlite"

  if [ "$($FRANKENPHP php-cli artisan tinker --execute='echo \Schema::hasTable("migrations") ? "yes" : "no";' 2>/dev/null || true)" = "yes" ]; then
    printf 'ok   migrations table\n'
  else
    printf 'fail migrations table\n'
    failures=$((failures + 1))
  fi

  if admin_exists; then
    printf 'ok   active system admin\n'
  else
    printf 'fail active system admin\n'
    failures=$((failures + 1))
  fi

  if [ "$($FRANKENPHP php-cli artisan tinker --execute='echo file_exists(public_path("dreamfactory/dist/index.html")) ? "yes" : "no";' 2>/dev/null || true)" = "yes" ]; then
    printf 'ok   admin UI asset\n'
  else
    printf 'fail admin UI asset\n'
    failures=$((failures + 1))
  fi

  return "$failures"
}

cmd_version() {
  local version_file="$SCRIPT_DIR/VERSION"
  local release_file="$SCRIPT_DIR/release.json"

  if [ -f "$release_file" ]; then
    cat "$release_file"
  elif [ -f "$version_file" ]; then
    printf 'DreamFactory Quickstart %s\n' "$(cat "$version_file")"
  else
    echo "DreamFactory Quickstart version metadata unavailable"
  fi
}

cmd_reset_admin() {
  require_frankenphp
  init_storage
  local email="$(admin_email)"
  local password="$(admin_password)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --email) email="$2"; shift 2 ;;
      --email=*) email="${1#*=}"; shift ;;
      --password) password="$2"; shift 2 ;;
      --password=*) password="${1#*=}"; shift ;;
      *) shift ;;
    esac
  done

  if [ -z "$password" ]; then
    read -rsp "Admin password: " password
    echo ""
  fi
  if [ -z "$email" ]; then
    read -rp "Admin email: " email
  fi

  ensure_admin "$email" "$password"
  echo ""
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

api_url() {
  printf '%s' "${DREAMFACTORY_URL:-http://localhost:8080/api/v2}"
}

require_curl() {
  if ! command -v curl >/dev/null 2>&1; then
    echo "curl is required for this command" >&2
    return 1
  fi
}

require_sqlite3() {
  if ! command -v sqlite3 >/dev/null 2>&1; then
    echo "sqlite3 is required for this command" >&2
    return 1
  fi
}

require_psql() {
  if ! command -v psql >/dev/null 2>&1; then
    echo "psql is required for this command" >&2
    return 1
  fi
}

extract_session_token() {
  sed -n 's/.*"session_token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | tail -1
}

request_json() {
  local method="$1"
  local url="$2"
  local token="$3"
  local file="${4:-}"

  if [ -n "$file" ]; then
    curl -s -X "$method" "$url" \
      -H "Content-Type: application/json" \
      -H "X-DreamFactory-Session-Token: $token" \
      --data-binary "@$file"
  else
    curl -s -X "$method" "$url" \
      -H "X-DreamFactory-Session-Token: $token"
  fi
}

cmd_login() {
  require_curl

  local url="$(api_url)"
  local email="${ADMIN_EMAIL:-}"
  local password="${ADMIN_PASSWORD:-}"
  local token_only="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --url) url="$2"; shift 2 ;;
      --url=*) url="${1#*=}"; shift ;;
      --email) email="$2"; shift 2 ;;
      --email=*) email="${1#*=}"; shift ;;
      --password) password="$2"; shift 2 ;;
      --password=*) password="${1#*=}"; shift ;;
      --token-only) token_only="true"; shift ;;
      *) shift ;;
    esac
  done

  if [ -z "$email" ] || [ -z "$password" ]; then
    echo "Email and password are required. Pass --email/--password or set ADMIN_EMAIL/ADMIN_PASSWORD." >&2
    return 1
  fi

  local response
  response="$(curl -s -X POST "$url/system/admin/session" \
    --data-urlencode "email=$email" \
    --data-urlencode "password=$password")"

  if [ "$token_only" = "true" ]; then
    printf '%s\n' "$response" | extract_session_token
  else
    printf '%s\n' "$response"
  fi
}

session_token_from_args() {
  local url="$1"
  local token="$2"
  local email="$3"
  local password="$4"

  if [ -n "$token" ]; then
    printf '%s' "$token"
    return 0
  fi

  if [ -n "$email" ] && [ -n "$password" ]; then
    cmd_login --url "$url" --email "$email" --password "$password" --token-only
    return 0
  fi

  echo "A session token or admin credentials are required. Pass --session-token, set DREAMFACTORY_SESSION_TOKEN, or pass --email/--password." >&2
  return 1
}

service_payload_template() {
  local type="${1:-pgsql}"
  case "$type" in
    pgsql|postgres|postgresql)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "mydb",
      "label": "My PostgreSQL Database",
      "type": "pgsql",
      "is_active": true,
      "config": {
        "host": "localhost",
        "port": 5432,
        "database": "app",
        "username": "app",
        "password": "change-me"
      }
    }
  ]
}
JSON
      ;;
    mysql|mariadb)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "mydb",
      "label": "My MySQL Database",
      "type": "mysql",
      "is_active": true,
      "config": {
        "host": "localhost",
        "port": 3306,
        "database": "app",
        "username": "app",
        "password": "change-me"
      }
    }
  ]
}
JSON
      ;;
    sqlite)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "local_sqlite",
      "label": "Local SQLite Database",
      "type": "sqlite",
      "is_active": true,
      "config": {
        "database": "/path/to/database.sqlite"
      }
    }
  ]
}
JSON
      ;;
    rws)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "remote_api",
      "label": "Remote REST API",
      "type": "rws",
      "is_active": true,
      "config": {
        "base_url": "https://api.example.com"
      }
    }
  ]
}
JSON
      ;;
    soap)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "soap_api",
      "label": "SOAP API",
      "type": "soap",
      "is_active": true,
      "config": {
        "wsdl": "https://example.com/service.wsdl"
      }
    }
  ]
}
JSON
      ;;
    sqlsrv|mssql)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "sqlserver",
      "label": "SQL Server",
      "type": "sqlsrv",
      "is_active": true,
      "config": {
        "host": "localhost",
        "port": 1433,
        "database": "app",
        "username": "sa",
        "password": "change-me",
        "encrypt": true,
        "trust_server_certificate": true
      }
    }
  ]
}
JSON
      ;;
    *)
      echo "Unsupported service template: $(json_escape "$type")" >&2
      return 1
      ;;
  esac
}

supported_service_types() {
  cat <<'JSON'
{
  "resource": [
    {
      "name": "pgsql",
      "label": "PostgreSQL",
      "command": "dreamfactory service plan pgsql"
    },
    {
      "name": "mysql",
      "label": "MySQL / MariaDB",
      "command": "dreamfactory service plan mysql"
    },
    {
      "name": "sqlsrv",
      "label": "SQL Server",
      "command": "dreamfactory service plan sqlsrv"
    },
    {
      "name": "sqlite",
      "label": "SQLite",
      "command": "dreamfactory service plan sqlite"
    },
    {
      "name": "rws",
      "label": "Remote REST API",
      "command": "dreamfactory service plan rws"
    },
    {
      "name": "soap",
      "label": "SOAP",
      "command": "dreamfactory service plan soap"
    }
  ]
}
JSON
}

cmd_service() {
  local subcommand="${1:-help}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    supported-types|supported)
      supported_service_types
      ;;
    list-types|types)
      require_curl
      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email) email="$2"; shift 2 ;;
          --email=*) email="${1#*=}"; shift ;;
          --password) password="$2"; shift 2 ;;
          --password=*) password="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done
      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      request_json GET "$url/system/service_type" "$token"
      ;;
    plan)
      service_payload_template "${1:-pgsql}"
      ;;
    apply)
      require_curl
      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      local file=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email) email="$2"; shift 2 ;;
          --email=*) email="${1#*=}"; shift ;;
          --password) password="$2"; shift 2 ;;
          --password=*) password="${1#*=}"; shift ;;
          --file|-f) file="$2"; shift 2 ;;
          --file=*) file="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done
      if [ -z "$file" ] || [ ! -f "$file" ]; then
        echo "A service JSON file is required. Use --file service.json." >&2
        return 1
      fi
      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      request_json POST "$url/system/service" "$token" "$file"
      ;;
    inspect)
      require_curl
      local name="${1:-}"
      [ $# -gt 0 ] && shift || true
      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email) email="$2"; shift 2 ;;
          --email=*) email="${1#*=}"; shift ;;
          --password) password="$2"; shift 2 ;;
          --password=*) password="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done
      if [ -z "$name" ]; then
        echo "A service name is required." >&2
        return 1
      fi
      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      request_json GET "$url/$name/_table" "$token"
      ;;
    help|--help|-h)
      echo "Usage:"
      echo "  dreamfactory service supported-types"
      echo "  dreamfactory service list-types [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory service plan TYPE"
      echo "  dreamfactory service apply --file service.json [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory service inspect NAME [--email EMAIL --password PASSWORD]"
      ;;
    *)
      echo "Unknown service command: $subcommand" >&2
      return 1
      ;;
  esac
}

cmd_demo() {
  local subcommand="${1:-help}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    pgsql|postgres|postgresql)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        echo "Usage:"
        echo "  dreamfactory demo pgsql --db-host HOST --db-name DB --db-user USER --db-password PASS [--email EMAIL --password PASSWORD]"
        echo "  dreamfactory demo pgsql --skip-seed --db-host HOST --db-name DB --db-user USER --db-password PASS"
        return 0
      fi

      require_curl
      require_psql

      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      local service_name="demo_pgsql"
      local db_host="localhost"
      local db_port="5432"
      local db_name="app"
      local db_user="app"
      local db_password="${PGPASSWORD:-}"
      local seed="true"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email|--admin-email) email="$2"; shift 2 ;;
          --email=*|--admin-email=*) email="${1#*=}"; shift ;;
          --password|--admin-password) password="$2"; shift 2 ;;
          --password=*|--admin-password=*) password="${1#*=}"; shift ;;
          --name|--service-name) service_name="$2"; shift 2 ;;
          --name=*|--service-name=*) service_name="${1#*=}"; shift ;;
          --db-host|--host) db_host="$2"; shift 2 ;;
          --db-host=*|--host=*) db_host="${1#*=}"; shift ;;
          --db-port|--port) db_port="$2"; shift 2 ;;
          --db-port=*|--port=*) db_port="${1#*=}"; shift ;;
          --db-name|--database) db_name="$2"; shift 2 ;;
          --db-name=*|--database=*) db_name="${1#*=}"; shift ;;
          --db-user|--username) db_user="$2"; shift 2 ;;
          --db-user=*|--username=*) db_user="${1#*=}"; shift ;;
          --db-password) db_password="$2"; shift 2 ;;
          --db-password=*) db_password="${1#*=}"; shift ;;
          --skip-seed) seed="false"; shift ;;
          *) shift ;;
        esac
      done

      if [ "$seed" = "true" ] && [ -z "$db_password" ]; then
        echo "PostgreSQL password is required for seeding. Pass --db-password or set PGPASSWORD." >&2
        return 1
      fi

      if [ "$seed" = "true" ]; then
        PGPASSWORD="$db_password" psql \
          -h "$db_host" \
          -p "$db_port" \
          -U "$db_user" \
          -d "$db_name" \
          -v ON_ERROR_STOP=1 >/dev/null <<'SQL'
SET client_min_messages TO warning;
CREATE TABLE IF NOT EXISTS widgets (
  id SERIAL PRIMARY KEY,
  name TEXT NOT NULL,
  status TEXT NOT NULL,
  quantity INTEGER NOT NULL,
  updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);
TRUNCATE widgets RESTART IDENTITY;
INSERT INTO widgets (name, status, quantity) VALUES
  ('starter-kit', 'ready', 42),
  ('field-gateway', 'testing', 12),
  ('analytics-feed', 'ready', 7);
SQL
      fi

      local payload
      payload="$(mktemp)"
      cat > "$payload" <<JSON
{
  "resource": [
    {
      "name": "$(json_escape "$service_name")",
      "label": "DreamFactory PostgreSQL Demo",
      "type": "pgsql",
      "is_active": true,
      "config": {
        "host": "$(json_escape "$db_host")",
        "port": $db_port,
        "database": "$(json_escape "$db_name")",
        "username": "$(json_escape "$db_user")",
        "password": "$(json_escape "$db_password")"
      }
    }
  ]
}
JSON

      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      local response
      response="$(request_json POST "$url/system/service" "$token" "$payload")"
      rm -f "$payload"

      cat <<JSON
{
  "service": "$service_name",
  "database": {
    "host": "$db_host",
    "port": $db_port,
    "name": "$db_name",
    "username": "$db_user"
  },
  "seeded": $seed,
  "apply_response": $response,
  "next": {
    "tables": "$url/$service_name/_table",
    "widgets": "$url/$service_name/_table/widgets"
  }
}
JSON
      ;;
    sqlite)
      require_curl
      require_sqlite3
      init_storage

      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      local name="demo_sqlite"
      local db_file="$STORAGE/databases/demo.sqlite"
      local force="false"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email) email="$2"; shift 2 ;;
          --email=*) email="${1#*=}"; shift ;;
          --password) password="$2"; shift 2 ;;
          --password=*) password="${1#*=}"; shift ;;
          --name) name="$2"; shift 2 ;;
          --name=*) name="${1#*=}"; shift ;;
          --database) db_file="$2"; shift 2 ;;
          --database=*) db_file="${1#*=}"; shift ;;
          --force) force="true"; shift ;;
          *) shift ;;
        esac
      done

      mkdir -p "$(dirname "$db_file")"
      if [ "$force" = "true" ]; then
        rm -f "$db_file"
      fi

      sqlite3 "$db_file" <<'SQL'
CREATE TABLE IF NOT EXISTS widgets (
  id INTEGER PRIMARY KEY,
  name TEXT NOT NULL,
  status TEXT NOT NULL,
  quantity INTEGER NOT NULL,
  updated_at TEXT NOT NULL
);
DELETE FROM widgets;
INSERT INTO widgets (id, name, status, quantity, updated_at) VALUES
  (1, 'starter-kit', 'ready', 42, '2026-05-05T00:00:00Z'),
  (2, 'field-gateway', 'testing', 12, '2026-05-05T00:00:00Z'),
  (3, 'analytics-feed', 'ready', 7, '2026-05-05T00:00:00Z');
CREATE TABLE IF NOT EXISTS sites (
  id INTEGER PRIMARY KEY,
  name TEXT NOT NULL,
  region TEXT NOT NULL
);
DELETE FROM sites;
INSERT INTO sites (id, name, region) VALUES
  (1, 'Denver Lab', 'us-west'),
  (2, 'Austin Demo', 'us-central');
SQL

      local payload
      payload="$(mktemp)"
      cat > "$payload" <<JSON
{
  "resource": [
    {
      "name": "$name",
      "label": "DreamFactory SQLite Demo",
      "type": "sqlite",
      "is_active": true,
      "config": {
        "database": "$db_file"
      }
    }
  ]
}
JSON

      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      local response
      response="$(request_json POST "$url/system/service" "$token" "$payload")"
      rm -f "$payload"

      cat <<JSON
{
  "service": "$name",
  "database": "$db_file",
  "apply_response": $response,
  "next": {
    "tables": "$url/$name/_table",
    "widgets": "$url/$name/_table/widgets",
    "sites": "$url/$name/_table/sites"
  }
}
JSON
      ;;
    help|--help|-h)
      echo "Usage:"
      echo "  dreamfactory demo pgsql --db-host HOST --db-name DB --db-user USER --db-password PASS [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory demo pgsql --skip-seed --db-host HOST --db-name DB --db-user USER --db-password PASS"
      echo "  dreamfactory demo sqlite [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory demo sqlite --name demo_sqlite --force"
      ;;
    *)
      echo "Unknown demo command: $subcommand" >&2
      return 1
      ;;
  esac
}

cmd_ai() {
  local subcommand="${1:-spec}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    spec)
      cat <<'JSON'
{
  "name": "dreamfactory-quickstart",
  "purpose": "Fast DreamFactory deployment for governed AI data access",
  "base_url": "http://localhost:8080/api/v2",
  "auth": {
    "admin_login": {
      "method": "POST",
      "path": "/system/admin/session",
      "content_type": "application/x-www-form-urlencoded",
      "returns": "session_token"
    },
    "headers": {
      "session": "X-DreamFactory-Session-Token",
      "api_key": "X-DreamFactory-API-Key"
    }
  },
  "binary_connectors": ["pgsql", "mysql", "sqlsrv", "sqlite", "rws", "soap"],
  "docker_connectors": ["pgsql", "mysql", "sqlsrv", "sqlite", "rws", "soap"],
  "planned_binary_connectors": [],
  "ai_commands": {
    "spec": "Print this machine-readable capability document",
    "login": "Exchange admin credentials for a session token",
    "plan-service": "Emit a service creation payload template",
    "apply-service": "Create a service from a JSON file",
    "supported-service-types": "List quickstart-supported service types",
    "list-service-types": "List available service types",
    "inspect-service": "Inspect table metadata for a service",
    "demo-pgsql": "Seed and register a PostgreSQL demo service",
    "demo-sqlite": "Create and register a local SQLite demo service"
  },
  "human_commands": {
    "login": "Login and print session JSON",
    "demo pgsql": "Seed and register a PostgreSQL demo service",
    "demo sqlite": "Create and register a local SQLite smoke-test service",
    "service list-types": "List available service types",
    "service supported-types": "List quickstart-supported service types",
    "service plan": "Print a service creation payload template",
    "service apply": "Create a service from JSON",
    "service inspect": "Inspect table metadata for a service"
  }
}
JSON
      ;;
    login)
      cmd_login "$@"
      ;;
    plan-service)
      service_payload_template "${1:-pgsql}"
      ;;
    apply-service)
      cmd_service apply "$@"
      ;;
    supported-service-types)
      cmd_service supported-types
      ;;
    list-service-types)
      cmd_service list-types "$@"
      ;;
    inspect-service)
      cmd_service inspect "$@"
      ;;
    demo-pgsql)
      cmd_demo pgsql "$@"
      ;;
    demo-sqlite)
      cmd_demo sqlite "$@"
      ;;
    *)
      echo "Unknown ai command: $subcommand" >&2
      return 1
      ;;
  esac
}

# --- Main ---
case "${1:-serve}" in
  serve)
    shift 2>/dev/null || true
    cmd_serve "$@"
    ;;
  setup)
    shift
    run_setup "$@"
    ;;
  doctor)
    cmd_doctor
    ;;
  version|--version|-v)
    cmd_version
    ;;
  login)
    shift
    cmd_login "$@"
    ;;
  demo)
    shift
    cmd_demo "$@"
    ;;
  service)
    shift
    cmd_service "$@"
    ;;
  reset-admin)
    shift
    cmd_reset_admin "$@"
    ;;
  ai)
    shift
    cmd_ai "$@"
    ;;
  migrate)
    require_frankenphp
    init_storage
    $FRANKENPHP php-cli artisan migrate --force "$@"
    ;;
  artisan)
    shift
    cmd_artisan "$@"
    ;;
  help|--help|-h)
    echo "DreamFactory Quickstart — Instant governed APIs from your data"
    echo ""
    echo "Usage:"
    echo "  dreamfactory serve [--host HOST] [--port PORT] [--admin-email EMAIL] [--admin-password PASSWORD]"
    echo "  dreamfactory setup [--admin-email EMAIL] [--admin-password PASSWORD]"
    echo "  dreamfactory doctor                Check runtime readiness"
    echo "  dreamfactory version               Print package version metadata"
    echo "  dreamfactory login                 Login and print session JSON"
    echo "  dreamfactory demo pgsql            Create and register a PostgreSQL demo"
    echo "  dreamfactory demo sqlite           Create and register a local SQLite smoke test"
    echo "  dreamfactory service supported-types List quickstart-supported service types"
    echo "  dreamfactory service list-types    List available service types"
    echo "  dreamfactory service plan TYPE     Print service payload template"
    echo "  dreamfactory service apply --file F Create a service from JSON"
    echo "  dreamfactory service inspect NAME  Inspect service table metadata"
    echo "  dreamfactory reset-admin           Create or reset the admin user"
    echo "  dreamfactory ai spec               Print AI helper capabilities"
    echo "  dreamfactory ai login              Login and print session JSON"
    echo "  dreamfactory ai plan-service TYPE  Print service payload template"
    echo "  dreamfactory ai apply-service --file F Create a service from JSON"
    echo "  dreamfactory ai supported-service-types List quickstart-supported service types"
    echo "  dreamfactory ai demo-pgsql         Create and register a PostgreSQL demo"
    echo "  dreamfactory ai demo-sqlite        Create and register a local SQLite smoke test"
    echo "  dreamfactory migrate               Run database migrations"
    echo "  dreamfactory artisan [...]          Run any artisan command"
    echo ""
    echo "Environment:"
    echo "  DREAMFACTORY_STORAGE   Data directory (default: ~/.dreamfactory)"
    echo "  ADMIN_EMAIL            Admin email for first-run setup"
    echo "  ADMIN_PASSWORD         Admin password for first-run setup"
    echo "  LISTEN_HOST            Bind host (default: 0.0.0.0)"
    echo "  SERVER_PORT            Listen port (default: 8080)"
    echo "  DREAMFACTORY_URL       API URL for CLI calls"
    echo "  DREAMFACTORY_SESSION_TOKEN Session token for CLI calls"
    ;;
  *)
    cmd_artisan "$@"
    ;;
esac
