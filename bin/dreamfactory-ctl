#!/usr/bin/env bash
#
# dreamfactory — DreamFactory Quickstart CLI
#
# Usage:
#   dreamfactory serve [--port PORT]     Start the API server
#   dreamfactory serve --with-mcp        Start the API server and bundled MCP daemon
#   dreamfactory setup                   Run first-time setup interactively
#   dreamfactory doctor                  Check binary runtime readiness
#   dreamfactory mcp doctor              Check bundled MCP daemon readiness
#   dreamfactory mcp serve               Start only the bundled MCP daemon
#   dreamfactory version                 Print package version metadata
#   dreamfactory login                   Login and print session JSON
#   dreamfactory quickstart pgsql        Connect PostgreSQL and print next steps
#   dreamfactory pgsql connect           Register a PostgreSQL service
#   dreamfactory demo pgsql              Create and register a PostgreSQL demo
#   dreamfactory demo sqlite             Create and register a local SQLite demo
#   dreamfactory service supported-types List quickstart-supported service types
#   dreamfactory service list-types      List available service types
#   dreamfactory service plan TYPE       Print a service payload template
#   dreamfactory service apply --file F  Create a service from JSON
#   dreamfactory service inspect NAME    Inspect service metadata
#   dreamfactory reset-admin             Create or reset the admin user
#   dreamfactory ai spec                 Print machine-readable AI helper spec
#   dreamfactory migrate                 Run database migrations
#   dreamfactory artisan [...]           Run any artisan command
#
# Environment:
#   DREAMFACTORY_STORAGE  Persistent data directory (default: ~/.dreamfactory)
#   ADMIN_EMAIL           Admin email for first-run setup
#   ADMIN_PASSWORD        Admin password for first-run setup (min 16 chars)
#   LISTEN_HOST           Host to bind (default: 0.0.0.0)
#   SERVER_PORT           Port to listen on (default: 8080)
#   MCP_DAEMON_PORT       MCP daemon port (default: 8006)
#   DREAMFACTORY_URL      API URL for CLI calls (default: http://localhost:8080/api/v2)
#   DREAMFACTORY_SESSION_TOKEN  Session token for authenticated CLI calls
#   MCP_DAEMON_URL        MCP daemon URL for client config (default: http://127.0.0.1:8006)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# The frankenphp binary, when a command needs the embedded app runtime.
FRANKENPHP=""
if [ -x "$SCRIPT_DIR/frankenphp" ]; then
  FRANKENPHP="$SCRIPT_DIR/frankenphp"
elif command -v frankenphp &>/dev/null; then
  FRANKENPHP="frankenphp"
else
  # We might be running inside the embedded binary itself
  FRANKENPHP="$(cd "$(dirname "$0")/.." && pwd)/frankenphp"
  if [ ! -x "$FRANKENPHP" ]; then
    FRANKENPHP=""
  fi
fi

STORAGE="${DREAMFACTORY_STORAGE:-$HOME/.dreamfactory}"
export LARAVEL_STORAGE_PATH="$STORAGE"
MCP_DAEMON_DIR="$SCRIPT_DIR/mcp-daemon"
MCP_NODE="$SCRIPT_DIR/node/bin/node"
MCP_PID=""

configure_bundled_odbc() {
  local odbc_dir="$SCRIPT_DIR/odbc"
  local driver_path
  driver_path="$(find "$odbc_dir/microsoft/msodbcsql18/lib64" -maxdepth 1 -name 'libmsodbcsql-*.so*' -type f 2>/dev/null | sort | tail -1 || true)"

  if [ -n "$driver_path" ]; then
    export LD_LIBRARY_PATH="$odbc_dir/lib:$odbc_dir/microsoft/msodbcsql18/lib64:${LD_LIBRARY_PATH:-}"
    export ODBCSYSINI="$STORAGE/odbc"
    export ODBCINI="$STORAGE/odbc/odbc.ini"
    mkdir -p "$STORAGE/odbc"
    cat > "$STORAGE/odbc/odbcinst.ini" <<ODBC
[ODBC Driver 18 for SQL Server]
Description=Microsoft ODBC Driver 18 for SQL Server
Driver=$driver_path
UsageCount=1
ODBC
    [ -f "$STORAGE/odbc/odbc.ini" ] || : > "$STORAGE/odbc/odbc.ini"
  fi
}

configure_bundled_odbc

configure_bundled_node() {
  local node_dir="$SCRIPT_DIR/node"

  if [ -x "$MCP_NODE" ]; then
    export LD_LIBRARY_PATH="$node_dir/lib:${LD_LIBRARY_PATH:-}"
  fi
}

configure_bundled_node

require_frankenphp() {
  if [ -z "$FRANKENPHP" ]; then
    echo "Error: frankenphp binary not found" >&2
    return 1
  fi
  if [ ! -x "$FRANKENPHP" ] && ! command -v "$FRANKENPHP" >/dev/null 2>&1; then
    echo "Error: frankenphp binary not found" >&2
    return 1
  fi
}

mcp_node() {
  if [ -x "$MCP_NODE" ]; then
    printf '%s' "$MCP_NODE"
  elif command -v node >/dev/null 2>&1; then
    command -v node
  else
    return 1
  fi
}

require_mcp() {
  if [ ! -f "$MCP_DAEMON_DIR/dist/server.js" ]; then
    echo "Error: bundled MCP daemon not found. Use an MCP-enabled DreamFactory artifact." >&2
    return 1
  fi
  if ! mcp_node >/dev/null 2>&1; then
    echo "Error: node runtime not found. Use an MCP-enabled artifact with bundled Node." >&2
    return 1
  fi
}

mcp_url() {
  if [ -n "${MCP_DAEMON_URL:-}" ]; then
    printf '%s' "$MCP_DAEMON_URL"
    return 0
  fi
  printf 'http://%s:%s' "${MCP_DAEMON_HOST:-127.0.0.1}" "${MCP_DAEMON_PORT:-8006}"
}

stop_mcp_daemon() {
  if [ -n "$MCP_PID" ] && kill -0 "$MCP_PID" 2>/dev/null; then
    kill "$MCP_PID" 2>/dev/null || true
    wait "$MCP_PID" 2>/dev/null || true
  fi
}

start_mcp_daemon() {
  require_mcp
  init_storage

  local host="${MCP_DAEMON_HOST:-127.0.0.1}"
  local port="${MCP_DAEMON_PORT:-8006}"
  local base_url="${MCP_INTERNAL_BASE_URL:-http://127.0.0.1:${SERVER_PORT:-8080}/api/v2}"
  local log="$STORAGE/logs/mcp-daemon.log"
  local node_bin
  node_bin="$(mcp_node)"

  export MCP_DAEMON_ENABLED="${MCP_DAEMON_ENABLED:-true}"
  export MCP_DAEMON_HOST="$host"
  export MCP_DAEMON_PORT="$port"
  export MCP_DAEMON_URL="${MCP_DAEMON_URL:-http://$host:$port}"
  export MCP_INTERNAL_BASE_URL="$base_url"

  mkdir -p "$STORAGE/logs"
  (
    cd "$MCP_DAEMON_DIR"
    exec "$node_bin" dist/server.js
  ) >>"$log" 2>&1 &
  MCP_PID="$!"

  if command -v curl >/dev/null 2>&1; then
    for _ in $(seq 1 30); do
      if ! kill -0 "$MCP_PID" 2>/dev/null; then
        echo "MCP daemon exited early. Last log lines:" >&2
        tail -40 "$log" >&2 || true
        return 1
      fi
      if curl -fsS "$(mcp_url)/health" >/dev/null 2>&1; then
        return 0
      fi
      sleep 1
    done
    echo "Timed out waiting for MCP daemon at $(mcp_url). Last log lines:" >&2
    tail -40 "$log" >&2 || true
    return 1
  fi
}

init_storage() {
  if [ ! -d "$STORAGE" ]; then
    echo "Initializing storage at $STORAGE ..."
  fi

  mkdir -p "$STORAGE/databases" \
           "$STORAGE/app" \
           "$STORAGE/framework/cache/data" \
           "$STORAGE/framework/sessions" \
           "$STORAGE/framework/views" \
           "$STORAGE/logs" \
           "$STORAGE/odbc"

  if [ ! -f "$STORAGE/databases/database.sqlite" ]; then
    touch "$STORAGE/databases/database.sqlite"
  fi
}

needs_setup() {
  [ ! -f "$STORAGE/.initialized" ]
}

admin_email() {
  printf '%s' "${ADMIN_EMAIL:-}"
}

admin_password() {
  printf '%s' "${ADMIN_PASSWORD:-}"
}

ensure_admin() {
  local email="$1"
  local password="$2"

  if [ -z "$email" ] || [ -z "$password" ]; then
    echo "Admin email and password are required." >&2
    return 1
  fi

  ADMIN_EMAIL="$email" ADMIN_PASSWORD="$password" $FRANKENPHP php-cli artisan tinker --execute='
    $email = getenv("ADMIN_EMAIL") ?: "";
    $password = getenv("ADMIN_PASSWORD") ?: "";
    if ($email === "" || $password === "") {
      fwrite(STDERR, "Admin email and password are required.\n");
      exit(1);
    }
    if (!\Schema::hasTable("user")) {
      fwrite(STDERR, "User table is missing. Run migrations/setup first.\n");
      exit(1);
    }
    $user = \DreamFactory\Core\Models\User::where("email", $email)->first();
    if ($user) {
      $user->password = $password;
      $user->is_sys_admin = true;
      $user->is_active = true;
      $user->save();
      echo "Admin ready.";
    } else {
      \DB::table("user")->insert([
        "name" => trim((getenv("ADMIN_FIRST_NAME") ?: "Admin") . " " . (getenv("ADMIN_LAST_NAME") ?: "User")),
        "first_name" => getenv("ADMIN_FIRST_NAME") ?: "Admin",
        "last_name" => getenv("ADMIN_LAST_NAME") ?: "User",
        "email" => $email,
        "username" => $email,
        "password" => \Hash::make($password),
        "is_sys_admin" => true,
        "is_active" => true,
        "phone" => getenv("ADMIN_PHONE") ?: "5555555555",
        "created_date" => now(),
        "last_modified_date" => now()
      ]);
      echo "Admin inserted.";
    }
  '
}

admin_exists() {
  local count
  count="$($FRANKENPHP php-cli artisan tinker --execute='
    echo \Schema::hasTable("user") ? \DB::table("user")->where("is_sys_admin", 1)->where("is_active", 1)->count() : 0;
  ' 2>/dev/null || true)"
  [ "${count##*$'\n'}" != "0" ]
}

write_caddyfile() {
  local host="$1"
  local port="$2"
  local caddyfile="$STORAGE/Caddyfile"
  local listen="$host:$port"

  if [ "$host" = "0.0.0.0" ]; then
    listen=":$port"
  fi

  cat > "$caddyfile" <<CADDY
{
	frankenphp
	order php_server before file_server
	admin off
}

$listen {
	root * public
	encode zstd gzip

	redir / /dreamfactory/dist/index.html 302
	redir /dreamfactory /dreamfactory/dist/index.html 302
	redir /dreamfactory/ /dreamfactory/dist/index.html 302
	redir /dreamfactory/dist /dreamfactory/dist/index.html 302
	redir /dreamfactory/dist/ /dreamfactory/dist/index.html 302

	php_server {
		resolve_root_symlink
	}
}
CADDY

  printf '%s' "$caddyfile"
}

run_setup() {
  require_frankenphp
  init_storage

  local email="${ADMIN_EMAIL:-}"
  local password="${ADMIN_PASSWORD:-}"
  local non_interactive="${NON_INTERACTIVE_SETUP:-false}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --admin-email|--email) email="$2"; shift 2 ;;
      --admin-email=*|--email=*) email="${1#*=}"; shift ;;
      --admin-password|--password) password="$2"; shift 2 ;;
      --admin-password=*|--password=*) password="${1#*=}"; shift ;;
      --non-interactive) non_interactive="true"; shift ;;
      *) shift ;;
    esac
  done

  echo "============================================"
  echo "  DreamFactory Quickstart — First-Time Setup"
  echo "============================================"
  echo ""

  # Generate APP_KEY if not set
  echo "Generating application key..."
  $FRANKENPHP php-cli artisan key:generate --force 2>/dev/null || true

  # Run migrations
  echo "Running database migrations..."
  $FRANKENPHP php-cli artisan migrate --force --seed 2>&1 | tail -5

  # Run DF setup
  echo "Configuring DreamFactory..."
  $FRANKENPHP php-cli artisan df:setup --force 2>/dev/null || true

  # Create admin user
  if [ -z "$email" ]; then
    if [ "$non_interactive" = "true" ]; then
      echo "Admin email is required. Pass --admin-email or set ADMIN_EMAIL." >&2
      return 1
    fi
    read -rp "Admin email: " email
  fi
  if [ -z "$password" ]; then
    if [ "$non_interactive" = "true" ]; then
      echo "Admin password is required. Pass --admin-password or set ADMIN_PASSWORD." >&2
      return 1
    fi
    read -rsp "Admin password (min 16 chars): " password
    echo ""
  fi

  if [ -n "$email" ] && [ -n "$password" ]; then
    $FRANKENPHP php-cli artisan df:setup \
      --admin_email "$email" \
      --admin_password "$password" \
      --admin_first_name "${ADMIN_FIRST_NAME:-Admin}" \
      --admin_last_name "${ADMIN_LAST_NAME:-User}" \
      --admin_phone "${ADMIN_PHONE:-5555555555}" \
      --force 2>&1 | grep -v "password" || true

    # df:setup can return successfully without creating the admin user in the
    # embedded binary runtime. Ensure the account exists before marking setup.
    ensure_admin "$email" "$password"
  fi

  # Clean up service types not in the quickstart profile.
  $FRANKENPHP php-cli artisan tinker --execute='
    if(\Schema::hasTable("service_type")){
      $remove = ["alloydb","cache_local","cache_memcached","cache_redis","ftp_file","local_file","sftp_file","webdav_file"];
      $count = \DB::table("service_type")->whereIn("name", $remove)->delete();
      echo "Cleaned $count unused service types.";
    }
  ' 2>/dev/null || true

  # Seed CORS
  $FRANKENPHP php-cli artisan tinker --execute='
    if(\Schema::hasTable("cors_config") && \DB::table("cors_config")->count() === 0){
      \DB::table("cors_config")->insert(["path"=>"*","origin"=>"*","header"=>"*","method"=>"*","max_age"=>0,"supports_credentials"=>false,"enabled"=>true]);
      echo "CORS config seeded.";
    }
  ' 2>/dev/null || true

  if ! admin_exists; then
    echo "Setup did not create an active system admin." >&2
    return 1
  fi

  touch "$STORAGE/.initialized"
  echo ""
  echo "Setup complete!"
}

cmd_serve() {
  require_frankenphp
  local port="${SERVER_PORT:-8080}"
  local host="${LISTEN_HOST:-0.0.0.0}"
  local with_mcp="${WITH_MCP:-false}"
  local setup_args=()

  # Parse --port flag
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --host) host="$2"; shift 2 ;;
      --host=*) host="${1#*=}"; shift ;;
      --port) port="$2"; shift 2 ;;
      --port=*) port="${1#*=}"; shift ;;
      --with-mcp) with_mcp="true"; shift ;;
      --mcp-port) export MCP_DAEMON_PORT="$2"; shift 2 ;;
      --mcp-port=*) export MCP_DAEMON_PORT="${1#*=}"; shift ;;
      --admin-email|--email)
        setup_args+=("--admin-email" "$2")
        shift 2
        ;;
      --admin-email=*|--email=*)
        setup_args+=("--admin-email" "${1#*=}")
        shift
        ;;
      --admin-password|--password)
        setup_args+=("--admin-password" "$2")
        shift 2
        ;;
      --admin-password=*|--password=*)
        setup_args+=("--admin-password" "${1#*=}")
        shift
        ;;
      --non-interactive)
        setup_args+=("--non-interactive")
        shift
        ;;
      *) shift ;;
    esac
  done

  init_storage
  export SERVER_PORT="$port"

  if needs_setup; then
    run_setup "${setup_args[@]}"
  fi

  if [ "$with_mcp" = "true" ]; then
    start_mcp_daemon
  fi

  echo ""
  echo "============================================"
  echo "  DreamFactory Quickstart"
  echo "  Admin UI: http://localhost:$port/"
  echo "  API:      http://localhost:$port/api/v2"
  if [ "$with_mcp" = "true" ]; then
    echo "  MCP:      $(mcp_url)"
  fi
  echo "  Listen:   http://$host:$port"
  echo "  Storage:  $STORAGE"
  echo "============================================"
  echo ""

  # FrankenPHP cd's into the embedded app dir at startup, so relative Caddy
  # roots point to the Laravel app within the embed.
  if [ "$with_mcp" = "true" ]; then
    local franken_pid=""
    cleanup_serve() {
      stop_mcp_daemon
      if [ -n "$franken_pid" ] && kill -0 "$franken_pid" 2>/dev/null; then
        kill "$franken_pid" 2>/dev/null || true
        wait "$franken_pid" 2>/dev/null || true
      fi
    }
    trap cleanup_serve EXIT INT TERM
    $FRANKENPHP run --config "$(write_caddyfile "$host" "$port")" &
    franken_pid="$!"
    wait "$franken_pid"
  else
    exec $FRANKENPHP run --config "$(write_caddyfile "$host" "$port")"
  fi
}

cmd_artisan() {
  require_frankenphp
  init_storage
  exec $FRANKENPHP php-cli artisan "$@"
}

cmd_doctor() {
  require_frankenphp
  init_storage
  local failures=0

  check() {
    local name="$1"
    shift
    if "$@" >/dev/null 2>&1; then
      printf 'ok   %s\n' "$name"
    else
      printf 'fail %s\n' "$name"
      failures=$((failures + 1))
    fi
  }

  check "frankenphp binary" "$FRANKENPHP" version
  check "embedded Laravel app" "$FRANKENPHP" php-cli artisan --version
  check "storage writable" test -w "$STORAGE"
  check "sqlite database" test -f "$STORAGE/databases/database.sqlite"

  if [ "$($FRANKENPHP php-cli artisan tinker --execute='echo \Schema::hasTable("migrations") ? "yes" : "no";' 2>/dev/null || true)" = "yes" ]; then
    printf 'ok   migrations table\n'
  else
    printf 'fail migrations table\n'
    failures=$((failures + 1))
  fi

  if admin_exists; then
    printf 'ok   active system admin\n'
  else
    printf 'fail active system admin\n'
    failures=$((failures + 1))
  fi

  if [ "$($FRANKENPHP php-cli artisan tinker --execute='echo file_exists(public_path("dreamfactory/dist/index.html")) ? "yes" : "no";' 2>/dev/null || true)" = "yes" ]; then
    printf 'ok   admin UI asset\n'
  else
    printf 'fail admin UI asset\n'
    failures=$((failures + 1))
  fi

  if [ -f "$MCP_DAEMON_DIR/dist/server.js" ]; then
    if mcp_node >/dev/null 2>&1; then
      printf 'ok   MCP daemon bundle\n'
    else
      printf 'fail MCP daemon node runtime\n'
      failures=$((failures + 1))
    fi
  fi

  return "$failures"
}

cmd_mcp() {
  local subcommand="${1:-help}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    serve)
      require_mcp
      init_storage
      export MCP_DAEMON_HOST="${MCP_DAEMON_HOST:-127.0.0.1}"
      export MCP_DAEMON_PORT="${MCP_DAEMON_PORT:-8006}"
      export MCP_DAEMON_URL="${MCP_DAEMON_URL:-http://${MCP_DAEMON_HOST}:${MCP_DAEMON_PORT}}"
      export MCP_INTERNAL_BASE_URL="${MCP_INTERNAL_BASE_URL:-http://127.0.0.1:${SERVER_PORT:-8080}/api/v2}"
      echo "Starting MCP daemon at $MCP_DAEMON_URL"
      cd "$MCP_DAEMON_DIR"
      exec "$(mcp_node)" dist/server.js
      ;;
    doctor)
      local failures=0
      if [ -f "$MCP_DAEMON_DIR/dist/server.js" ]; then
        printf 'ok   MCP daemon files\n'
      else
        printf 'fail MCP daemon files\n'
        failures=$((failures + 1))
      fi
      if mcp_node >/dev/null 2>&1; then
        printf 'ok   node runtime\n'
        "$(mcp_node)" --version
      else
        printf 'fail node runtime\n'
        failures=$((failures + 1))
      fi
      if command -v curl >/dev/null 2>&1 && curl -fsS "$(mcp_url)/health" >/dev/null 2>&1; then
        printf 'ok   MCP daemon health\n'
      else
        printf 'warn MCP daemon health unavailable at %s\n' "$(mcp_url)"
      fi
      return "$failures"
      ;;
    url)
      mcp_url
      echo ""
      ;;
    config)
      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local service="${MCP_SERVICE_NAME:-local}"
      local client="generic"
      local format="json"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --service|--mcp-service) service="$2"; shift 2 ;;
          --service=*|--mcp-service=*) service="${1#*=}"; shift ;;
          --client) client="$2"; shift 2 ;;
          --client=*) client="${1#*=}"; shift ;;
          --format) format="$2"; shift 2 ;;
          --format=*) format="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done

      local endpoint
      endpoint="$(mcp_url)/mcp/$service"
      case "$format" in
        text)
          cat <<TEXT
MCP endpoint: $endpoint
DreamFactory API: $url

Headers:
  Accept: application/json, text/event-stream
  Content-Type: application/json
  X-Mcp-Base-Url: $url
  X-DreamFactory-Session-Token: $token

Plain-language questions are handled by the LLM client; DreamFactory exposes the authenticated data tools.
TEXT
          return 0
          ;;
        json) ;;
        *)
          echo "Unsupported MCP config format: $format" >&2
          return 1
          ;;
      esac

      case "$client" in
        generic)
          ;;
        claude)
          cat <<JSON
{
  "client": "claude",
  "type": "streamable-http",
  "url": "$(json_escape "$endpoint")",
  "headers": {
    "Accept": "application/json, text/event-stream",
    "Content-Type": "application/json",
    "X-Mcp-Base-Url": "$(json_escape "$url")",
    "X-DreamFactory-Session-Token": "$(json_escape "$token")"
  },
  "notes": [
    "Use this as the DreamFactory MCP server entry in a client that supports streamable HTTP MCP.",
    "If your Claude client only supports stdio MCP servers, use an MCP proxy or connector that can forward streamable HTTP."
  ]
}
JSON
          return 0
          ;;
        cursor)
          cat <<JSON
{
  "mcpServers": {
    "dreamfactory": {
      "type": "streamable-http",
      "url": "$(json_escape "$endpoint")",
      "headers": {
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json",
        "X-Mcp-Base-Url": "$(json_escape "$url")",
        "X-DreamFactory-Session-Token": "$(json_escape "$token")"
      }
    }
  }
}
JSON
          return 0
          ;;
        codex)
          cat <<JSON
{
  "mcp_servers": {
    "dreamfactory": {
      "transport": "streamable-http",
      "url": "$(json_escape "$endpoint")",
      "headers": {
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json",
        "X-Mcp-Base-Url": "$(json_escape "$url")",
        "X-DreamFactory-Session-Token": "$(json_escape "$token")"
      }
    }
  }
}
JSON
          return 0
          ;;
        *)
          echo "Unsupported MCP client: $client. Use generic, claude, cursor, or codex." >&2
          return 1
          ;;
      esac

      cat <<JSON
{
  "transport": "streamable-http",
  "mcp_url": "$(json_escape "$endpoint")",
  "dreamfactory_api_url": "$(json_escape "$url")",
  "headers": {
    "Accept": "application/json, text/event-stream",
    "Content-Type": "application/json",
    "X-Mcp-Base-Url": "$(json_escape "$url")",
    "X-DreamFactory-Session-Token": "$(json_escape "$token")"
  },
  "notes": [
    "Start DreamFactory with: dreamfactory serve --with-mcp",
    "Obtain a token with: dreamfactory login --token-only",
    "The LLM/client translates plain language into MCP tool calls."
  ]
}
JSON
      ;;
    help|--help|-h)
      echo "Usage:"
      echo "  dreamfactory mcp serve             Start the bundled MCP daemon"
      echo "  dreamfactory mcp doctor            Check MCP bundle and daemon health"
      echo "  dreamfactory mcp url               Print MCP daemon URL"
      echo "  dreamfactory mcp config            Print MCP client connection JSON"
      echo "  dreamfactory mcp config --client claude|cursor|codex"
      echo "  dreamfactory mcp config --format text"
      ;;
    *)
      echo "Unknown mcp command: $subcommand" >&2
      return 1
      ;;
  esac
}

cmd_version() {
  local version_file="$SCRIPT_DIR/VERSION"
  local release_file="$SCRIPT_DIR/release.json"

  if [ -f "$release_file" ]; then
    cat "$release_file"
  elif [ -f "$version_file" ]; then
    printf 'DreamFactory Quickstart %s\n' "$(cat "$version_file")"
  else
    echo "DreamFactory Quickstart version metadata unavailable"
  fi
}

cmd_reset_admin() {
  require_frankenphp
  init_storage
  local email="$(admin_email)"
  local password="$(admin_password)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --email) email="$2"; shift 2 ;;
      --email=*) email="${1#*=}"; shift ;;
      --password) password="$2"; shift 2 ;;
      --password=*) password="${1#*=}"; shift ;;
      *) shift ;;
    esac
  done

  if [ -z "$password" ]; then
    read -rsp "Admin password: " password
    echo ""
  fi
  if [ -z "$email" ]; then
    read -rp "Admin email: " email
  fi

  ensure_admin "$email" "$password"
  echo ""
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

api_url() {
  printf '%s' "${DREAMFACTORY_URL:-http://localhost:8080/api/v2}"
}

require_curl() {
  if ! command -v curl >/dev/null 2>&1; then
    echo "curl is required for this command" >&2
    return 1
  fi
}

require_sqlite3() {
  if ! command -v sqlite3 >/dev/null 2>&1; then
    echo "sqlite3 is required for this command" >&2
    return 1
  fi
}

require_psql() {
  if ! command -v psql >/dev/null 2>&1; then
    echo "psql is required for this command" >&2
    return 1
  fi
}

extract_session_token() {
  sed -n 's/.*"session_token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | tail -1
}

request_json() {
  local method="$1"
  local url="$2"
  local token="$3"
  local file="${4:-}"

  if [ -n "$file" ]; then
    curl -s -X "$method" "$url" \
      -H "Content-Type: application/json" \
      -H "X-DreamFactory-Session-Token: $token" \
      --data-binary "@$file"
  else
    curl -s -X "$method" "$url" \
      -H "X-DreamFactory-Session-Token: $token"
  fi
}

cmd_login() {
  require_curl

  local url="$(api_url)"
  local email="${ADMIN_EMAIL:-}"
  local password="${ADMIN_PASSWORD:-}"
  local token_only="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --url) url="$2"; shift 2 ;;
      --url=*) url="${1#*=}"; shift ;;
      --email) email="$2"; shift 2 ;;
      --email=*) email="${1#*=}"; shift ;;
      --password) password="$2"; shift 2 ;;
      --password=*) password="${1#*=}"; shift ;;
      --token-only) token_only="true"; shift ;;
      *) shift ;;
    esac
  done

  if [ -z "$email" ] || [ -z "$password" ]; then
    echo "Email and password are required. Pass --email/--password or set ADMIN_EMAIL/ADMIN_PASSWORD." >&2
    return 1
  fi

  local response
  response="$(curl -s -X POST "$url/system/admin/session" \
    --data-urlencode "email=$email" \
    --data-urlencode "password=$password")"

  if [ "$token_only" = "true" ]; then
    printf '%s\n' "$response" | extract_session_token
  else
    printf '%s\n' "$response"
  fi
}

session_token_from_args() {
  local url="$1"
  local token="$2"
  local email="$3"
  local password="$4"

  if [ -n "$token" ]; then
    printf '%s' "$token"
    return 0
  fi

  if [ -n "$email" ] && [ -n "$password" ]; then
    cmd_login --url "$url" --email "$email" --password "$password" --token-only
    return 0
  fi

  echo "A session token or admin credentials are required. Pass --session-token, set DREAMFACTORY_SESSION_TOKEN, or pass --email/--password." >&2
  return 1
}

service_payload_template() {
  local type="${1:-pgsql}"
  case "$type" in
    pgsql|postgres|postgresql)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "mydb",
      "label": "My PostgreSQL Database",
      "type": "pgsql",
      "is_active": true,
      "config": {
        "host": "localhost",
        "port": 5432,
        "database": "app",
        "username": "app",
        "password": "change-me"
      }
    }
  ]
}
JSON
      ;;
    mysql|mariadb)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "mydb",
      "label": "My MySQL Database",
      "type": "mysql",
      "is_active": true,
      "config": {
        "host": "localhost",
        "port": 3306,
        "database": "app",
        "username": "app",
        "password": "change-me"
      }
    }
  ]
}
JSON
      ;;
    sqlite)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "local_sqlite",
      "label": "Local SQLite Database",
      "type": "sqlite",
      "is_active": true,
      "config": {
        "database": "/path/to/database.sqlite"
      }
    }
  ]
}
JSON
      ;;
    rws)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "remote_api",
      "label": "Remote REST API",
      "type": "rws",
      "is_active": true,
      "config": {
        "base_url": "https://api.example.com"
      }
    }
  ]
}
JSON
      ;;
    soap)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "soap_api",
      "label": "SOAP API",
      "type": "soap",
      "is_active": true,
      "config": {
        "wsdl": "https://example.com/service.wsdl"
      }
    }
  ]
}
JSON
      ;;
    sqlsrv|mssql)
      cat <<'JSON'
{
  "resource": [
    {
      "name": "sqlserver",
      "label": "SQL Server",
      "type": "sqlsrv",
      "is_active": true,
      "config": {
        "host": "localhost",
        "port": 1433,
        "database": "app",
        "username": "sa",
        "password": "change-me",
        "encrypt": true,
        "trust_server_certificate": true
      }
    }
  ]
}
JSON
      ;;
    *)
      echo "Unsupported service template: $(json_escape "$type")" >&2
      return 1
      ;;
  esac
}

supported_service_types() {
  cat <<'JSON'
{
  "resource": [
    {
      "name": "pgsql",
      "label": "PostgreSQL",
      "command": "dreamfactory service plan pgsql"
    },
    {
      "name": "mysql",
      "label": "MySQL / MariaDB",
      "command": "dreamfactory service plan mysql"
    },
    {
      "name": "sqlsrv",
      "label": "SQL Server",
      "command": "dreamfactory service plan sqlsrv"
    },
    {
      "name": "sqlite",
      "label": "SQLite",
      "command": "dreamfactory service plan sqlite"
    },
    {
      "name": "rws",
      "label": "Remote REST API",
      "command": "dreamfactory service plan rws"
    },
    {
      "name": "soap",
      "label": "SOAP",
      "command": "dreamfactory service plan soap"
    }
  ]
}
JSON
}

cmd_service() {
  local subcommand="${1:-help}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    supported-types|supported)
      supported_service_types
      ;;
    list-types|types)
      require_curl
      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email) email="$2"; shift 2 ;;
          --email=*) email="${1#*=}"; shift ;;
          --password) password="$2"; shift 2 ;;
          --password=*) password="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done
      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      request_json GET "$url/system/service_type" "$token"
      ;;
    plan)
      service_payload_template "${1:-pgsql}"
      ;;
    apply)
      require_curl
      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      local file=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email) email="$2"; shift 2 ;;
          --email=*) email="${1#*=}"; shift ;;
          --password) password="$2"; shift 2 ;;
          --password=*) password="${1#*=}"; shift ;;
          --file|-f) file="$2"; shift 2 ;;
          --file=*) file="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done
      if [ -z "$file" ] || [ ! -f "$file" ]; then
        echo "A service JSON file is required. Use --file service.json." >&2
        return 1
      fi
      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      request_json POST "$url/system/service" "$token" "$file"
      ;;
    inspect)
      require_curl
      local name="${1:-}"
      [ $# -gt 0 ] && shift || true
      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email) email="$2"; shift 2 ;;
          --email=*) email="${1#*=}"; shift ;;
          --password) password="$2"; shift 2 ;;
          --password=*) password="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done
      if [ -z "$name" ]; then
        echo "A service name is required." >&2
        return 1
      fi
      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      request_json GET "$url/$name/_table" "$token"
      ;;
    help|--help|-h)
      echo "Usage:"
      echo "  dreamfactory service supported-types"
      echo "  dreamfactory service list-types [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory service plan TYPE"
      echo "  dreamfactory service apply --file service.json [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory service inspect NAME [--email EMAIL --password PASSWORD]"
      ;;
    *)
      echo "Unknown service command: $subcommand" >&2
      return 1
      ;;
  esac
}

cmd_pgsql() {
  local subcommand="${1:-help}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    connect)
      require_curl

      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      local service_name="pgsql"
      local label="PostgreSQL"
      local db_host="localhost"
      local db_port="5432"
      local db_name=""
      local db_user=""
      local db_password="${PGPASSWORD:-}"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email|--admin-email) email="$2"; shift 2 ;;
          --email=*|--admin-email=*) email="${1#*=}"; shift ;;
          --password|--admin-password) password="$2"; shift 2 ;;
          --password=*|--admin-password=*) password="${1#*=}"; shift ;;
          --name|--service-name) service_name="$2"; shift 2 ;;
          --name=*|--service-name=*) service_name="${1#*=}"; shift ;;
          --label) label="$2"; shift 2 ;;
          --label=*) label="${1#*=}"; shift ;;
          --db-host|--host) db_host="$2"; shift 2 ;;
          --db-host=*|--host=*) db_host="${1#*=}"; shift ;;
          --db-port|--port) db_port="$2"; shift 2 ;;
          --db-port=*|--port=*) db_port="${1#*=}"; shift ;;
          --db-name|--database) db_name="$2"; shift 2 ;;
          --db-name=*|--database=*) db_name="${1#*=}"; shift ;;
          --db-user|--username) db_user="$2"; shift 2 ;;
          --db-user=*|--username=*) db_user="${1#*=}"; shift ;;
          --db-password) db_password="$2"; shift 2 ;;
          --db-password=*) db_password="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done

      if [ -z "$db_name" ] || [ -z "$db_user" ]; then
        echo "PostgreSQL database and username are required. Pass --db-name and --db-user." >&2
        return 1
      fi
      if [ -z "$db_password" ]; then
        echo "PostgreSQL password is required. Pass --db-password or set PGPASSWORD." >&2
        return 1
      fi

      local payload
      payload="$(mktemp)"
      cat > "$payload" <<JSON
{
  "resource": [
    {
      "name": "$(json_escape "$service_name")",
      "label": "$(json_escape "$label")",
      "type": "pgsql",
      "is_active": true,
      "config": {
        "host": "$(json_escape "$db_host")",
        "port": $db_port,
        "database": "$(json_escape "$db_name")",
        "username": "$(json_escape "$db_user")",
        "password": "$(json_escape "$db_password")"
      }
    }
  ]
}
JSON

      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      local response
      response="$(request_json POST "$url/system/service" "$token" "$payload")"
      rm -f "$payload"

      cat <<JSON
{
  "service": "$(json_escape "$service_name")",
  "type": "pgsql",
  "api": {
    "tables": "$(json_escape "$url")/$(json_escape "$service_name")/_table"
  },
  "mcp": {
    "tool_prefix": "$(json_escape "$service_name")",
    "common_tools": [
      "$(json_escape "$service_name")_get_tables",
      "$(json_escape "$service_name")_get_table_schema",
      "$(json_escape "$service_name")_get_table_data"
    ],
    "config_command": "dreamfactory mcp config --session-token TOKEN"
  },
  "apply_response": $response
}
JSON
      ;;
    help|--help|-h)
      echo "Usage:"
      echo "  dreamfactory pgsql connect --db-host HOST --db-name DB --db-user USER --db-password PASS [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory pgsql connect --name app_pg --db-host HOST --db-name DB --db-user USER --db-password PASS"
      ;;
    *)
      echo "Unknown pgsql command: $subcommand" >&2
      return 1
      ;;
  esac
}

cmd_demo() {
  local subcommand="${1:-help}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    pgsql|postgres|postgresql)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        echo "Usage:"
        echo "  dreamfactory demo pgsql --db-host HOST --db-name DB --db-user USER --db-password PASS [--email EMAIL --password PASSWORD]"
        echo "  dreamfactory demo pgsql --skip-seed --db-host HOST --db-name DB --db-user USER --db-password PASS"
        return 0
      fi

      require_curl
      require_psql

      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      local service_name="demo_pgsql"
      local db_host="localhost"
      local db_port="5432"
      local db_name="app"
      local db_user="app"
      local db_password="${PGPASSWORD:-}"
      local seed="true"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email|--admin-email) email="$2"; shift 2 ;;
          --email=*|--admin-email=*) email="${1#*=}"; shift ;;
          --password|--admin-password) password="$2"; shift 2 ;;
          --password=*|--admin-password=*) password="${1#*=}"; shift ;;
          --name|--service-name) service_name="$2"; shift 2 ;;
          --name=*|--service-name=*) service_name="${1#*=}"; shift ;;
          --db-host|--host) db_host="$2"; shift 2 ;;
          --db-host=*|--host=*) db_host="${1#*=}"; shift ;;
          --db-port|--port) db_port="$2"; shift 2 ;;
          --db-port=*|--port=*) db_port="${1#*=}"; shift ;;
          --db-name|--database) db_name="$2"; shift 2 ;;
          --db-name=*|--database=*) db_name="${1#*=}"; shift ;;
          --db-user|--username) db_user="$2"; shift 2 ;;
          --db-user=*|--username=*) db_user="${1#*=}"; shift ;;
          --db-password) db_password="$2"; shift 2 ;;
          --db-password=*) db_password="${1#*=}"; shift ;;
          --skip-seed) seed="false"; shift ;;
          *) shift ;;
        esac
      done

      if [ "$seed" = "true" ] && [ -z "$db_password" ]; then
        echo "PostgreSQL password is required for seeding. Pass --db-password or set PGPASSWORD." >&2
        return 1
      fi

      if [ "$seed" = "true" ]; then
        PGPASSWORD="$db_password" psql \
          -h "$db_host" \
          -p "$db_port" \
          -U "$db_user" \
          -d "$db_name" \
          -v ON_ERROR_STOP=1 >/dev/null <<'SQL'
SET client_min_messages TO warning;
CREATE TABLE IF NOT EXISTS widgets (
  id SERIAL PRIMARY KEY,
  name TEXT NOT NULL,
  status TEXT NOT NULL,
  quantity INTEGER NOT NULL,
  updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);
TRUNCATE widgets RESTART IDENTITY;
INSERT INTO widgets (name, status, quantity) VALUES
  ('starter-kit', 'ready', 42),
  ('field-gateway', 'testing', 12),
  ('analytics-feed', 'ready', 7);
SQL
      fi

      local payload
      payload="$(mktemp)"
      cat > "$payload" <<JSON
{
  "resource": [
    {
      "name": "$(json_escape "$service_name")",
      "label": "DreamFactory PostgreSQL Demo",
      "type": "pgsql",
      "is_active": true,
      "config": {
        "host": "$(json_escape "$db_host")",
        "port": $db_port,
        "database": "$(json_escape "$db_name")",
        "username": "$(json_escape "$db_user")",
        "password": "$(json_escape "$db_password")"
      }
    }
  ]
}
JSON

      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      local response
      response="$(request_json POST "$url/system/service" "$token" "$payload")"
      rm -f "$payload"

      cat <<JSON
{
  "service": "$service_name",
  "database": {
    "host": "$db_host",
    "port": $db_port,
    "name": "$db_name",
    "username": "$db_user"
  },
  "seeded": $seed,
  "apply_response": $response,
  "next": {
    "tables": "$url/$service_name/_table",
    "widgets": "$url/$service_name/_table/widgets"
  }
}
JSON
      ;;
    sqlite)
      require_curl
      require_sqlite3
      init_storage

      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      local name="demo_sqlite"
      local db_file="$STORAGE/databases/demo.sqlite"
      local force="false"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email) email="$2"; shift 2 ;;
          --email=*) email="${1#*=}"; shift ;;
          --password) password="$2"; shift 2 ;;
          --password=*) password="${1#*=}"; shift ;;
          --name) name="$2"; shift 2 ;;
          --name=*) name="${1#*=}"; shift ;;
          --database) db_file="$2"; shift 2 ;;
          --database=*) db_file="${1#*=}"; shift ;;
          --force) force="true"; shift ;;
          *) shift ;;
        esac
      done

      mkdir -p "$(dirname "$db_file")"
      if [ "$force" = "true" ]; then
        rm -f "$db_file"
      fi

      sqlite3 "$db_file" <<'SQL'
CREATE TABLE IF NOT EXISTS widgets (
  id INTEGER PRIMARY KEY,
  name TEXT NOT NULL,
  status TEXT NOT NULL,
  quantity INTEGER NOT NULL,
  updated_at TEXT NOT NULL
);
DELETE FROM widgets;
INSERT INTO widgets (id, name, status, quantity, updated_at) VALUES
  (1, 'starter-kit', 'ready', 42, '2026-05-05T00:00:00Z'),
  (2, 'field-gateway', 'testing', 12, '2026-05-05T00:00:00Z'),
  (3, 'analytics-feed', 'ready', 7, '2026-05-05T00:00:00Z');
CREATE TABLE IF NOT EXISTS sites (
  id INTEGER PRIMARY KEY,
  name TEXT NOT NULL,
  region TEXT NOT NULL
);
DELETE FROM sites;
INSERT INTO sites (id, name, region) VALUES
  (1, 'Denver Lab', 'us-west'),
  (2, 'Austin Demo', 'us-central');
SQL

      local payload
      payload="$(mktemp)"
      cat > "$payload" <<JSON
{
  "resource": [
    {
      "name": "$name",
      "label": "DreamFactory SQLite Demo",
      "type": "sqlite",
      "is_active": true,
      "config": {
        "database": "$db_file"
      }
    }
  ]
}
JSON

      token="$(session_token_from_args "$url" "$token" "$email" "$password")"
      local response
      response="$(request_json POST "$url/system/service" "$token" "$payload")"
      rm -f "$payload"

      cat <<JSON
{
  "service": "$name",
  "database": "$db_file",
  "apply_response": $response,
  "next": {
    "tables": "$url/$name/_table",
    "widgets": "$url/$name/_table/widgets",
    "sites": "$url/$name/_table/sites"
  }
}
JSON
      ;;
    help|--help|-h)
      echo "Usage:"
      echo "  dreamfactory demo pgsql --db-host HOST --db-name DB --db-user USER --db-password PASS [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory demo pgsql --skip-seed --db-host HOST --db-name DB --db-user USER --db-password PASS"
      echo "  dreamfactory demo sqlite [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory demo sqlite --name demo_sqlite --force"
      ;;
    *)
      echo "Unknown demo command: $subcommand" >&2
      return 1
      ;;
  esac
}

cmd_quickstart() {
  local subcommand="${1:-help}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    pgsql|postgres|postgresql)
      require_curl

      local url="$(api_url)"
      local token="${DREAMFACTORY_SESSION_TOKEN:-}"
      local email="${ADMIN_EMAIL:-}"
      local password="${ADMIN_PASSWORD:-}"
      local service_name="app_pgsql"
      local mcp_service="${MCP_SERVICE_NAME:-local}"
      local format="json"
      local args=("$@")

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --url) url="$2"; shift 2 ;;
          --url=*) url="${1#*=}"; shift ;;
          --session-token|--token) token="$2"; shift 2 ;;
          --session-token=*|--token=*) token="${1#*=}"; shift ;;
          --email|--admin-email) email="$2"; shift 2 ;;
          --email=*|--admin-email=*) email="${1#*=}"; shift ;;
          --password|--admin-password) password="$2"; shift 2 ;;
          --password=*|--admin-password=*) password="${1#*=}"; shift ;;
          --name|--service-name) service_name="$2"; shift 2 ;;
          --name=*|--service-name=*) service_name="${1#*=}"; shift ;;
          --service|--mcp-service) mcp_service="$2"; shift 2 ;;
          --service=*|--mcp-service=*) mcp_service="${1#*=}"; shift ;;
          --format) format="$2"; shift 2 ;;
          --format=*) format="${1#*=}"; shift ;;
          *) shift ;;
        esac
      done

      local connect_args=()
      local i=0
      while [ "$i" -lt "${#args[@]}" ]; do
        case "${args[$i]}" in
          --format)
            i=$((i + 2))
            ;;
          --format=*)
            i=$((i + 1))
            ;;
          *)
            connect_args+=("${args[$i]}")
            i=$((i + 1))
            ;;
        esac
      done

      token="$(session_token_from_args "$url" "$token" "$email" "$password")"

      local connect_response
      connect_response="$(cmd_pgsql connect "${connect_args[@]}" --url "$url" --session-token "$token" --name "$service_name")"

      local tables_response
      tables_response="$(request_json GET "$url/$service_name/_table" "$token")"

      local verified="false"
      if printf '%s' "$tables_response" | grep -q '"resource"'; then
        verified="true"
      fi

      local first_table=""
      if command -v jq >/dev/null 2>&1; then
        first_table="$(printf '%s' "$tables_response" | jq -r '.resource[0].name // .resource[0] // empty' 2>/dev/null || true)"
      fi
      if [ -z "$first_table" ]; then
        first_table="$(printf '%s' "$tables_response" | sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
      fi
      if [ -z "$first_table" ]; then
        first_table="your_table"
      fi

      local mcp_config
      mcp_config="$(DREAMFACTORY_SESSION_TOKEN="$token" cmd_mcp config --url "$url" --service "$mcp_service")"

      case "$format" in
        text)
          cat <<TEXT
Connected: $service_name
Verified table list: $verified
API tables: $url/$service_name/_table
MCP endpoint: $(mcp_url)/mcp/$mcp_service

Try asking:
  List the tables in my PostgreSQL database.
  Show me 10 rows from $first_table.
  Summarize the schema for $first_table and suggest useful API endpoints.
  Identify fields in $first_table that may contain sensitive data.

Client config:
  dreamfactory mcp config --session-token "$token"
  dreamfactory mcp config --client claude --session-token "$token"
  dreamfactory mcp config --client cursor --session-token "$token"
  dreamfactory mcp config --client codex --session-token "$token"
TEXT
          return 0
          ;;
        json) ;;
        *)
          echo "Unsupported quickstart format: $format" >&2
          return 1
          ;;
      esac

      cat <<JSON
{
  "status": "ready",
  "service": "$(json_escape "$service_name")",
  "dreamfactory_api_url": "$(json_escape "$url")",
  "verified": {
    "table_list": $verified,
    "tables_endpoint": "$(json_escape "$url")/$(json_escape "$service_name")/_table"
  },
  "connect": $connect_response,
  "tables": $tables_response,
  "mcp": $mcp_config,
  "suggested_prompts": [
    "List the tables in my PostgreSQL database.",
    "Show me 10 rows from $(json_escape "$first_table").",
    "Summarize the schema for $(json_escape "$first_table") and suggest useful API endpoints.",
    "Identify fields in $(json_escape "$first_table") that may contain sensitive data."
  ]
}
JSON
      ;;
    help|--help|-h)
      echo "Usage:"
      echo "  dreamfactory quickstart pgsql --db-host HOST --db-name DB --db-user USER --db-password PASS [--email EMAIL --password PASSWORD]"
      echo "  dreamfactory quickstart pgsql --name app_pgsql --db-host HOST --db-name DB --db-user USER --db-password PASS"
      echo "  dreamfactory quickstart pgsql --format text --db-host HOST --db-name DB --db-user USER --db-password PASS"
      ;;
    *)
      echo "Unknown quickstart command: $subcommand" >&2
      return 1
      ;;
  esac
}

cmd_ai() {
  local subcommand="${1:-spec}"
  [ $# -gt 0 ] && shift || true

  case "$subcommand" in
    spec)
      cat <<'JSON'
{
  "name": "dreamfactory-quickstart",
  "purpose": "Fast DreamFactory deployment for governed AI data access",
  "base_url": "http://localhost:8080/api/v2",
  "auth": {
    "admin_login": {
      "method": "POST",
      "path": "/system/admin/session",
      "content_type": "application/x-www-form-urlencoded",
      "returns": "session_token"
    },
    "headers": {
      "session": "X-DreamFactory-Session-Token",
      "api_key": "X-DreamFactory-API-Key"
    }
  },
  "binary_connectors": ["pgsql", "mysql", "sqlsrv", "sqlite", "rws", "soap"],
  "docker_connectors": ["pgsql", "mysql", "sqlsrv", "sqlite", "rws", "soap"],
  "planned_binary_connectors": [],
  "mcp": {
    "serve": "dreamfactory serve --with-mcp",
    "doctor": "dreamfactory mcp doctor",
    "daemon_url": "http://127.0.0.1:8006"
  },
  "ai_commands": {
    "spec": "Print this machine-readable capability document",
    "login": "Exchange admin credentials for a session token",
    "quickstart-pgsql": "Register PostgreSQL, verify the API, print MCP config, and emit starter prompts",
    "pgsql-connect": "Register an existing PostgreSQL database as a DreamFactory service",
    "plan-service": "Emit a service creation payload template",
    "apply-service": "Create a service from a JSON file",
    "supported-service-types": "List quickstart-supported service types",
    "list-service-types": "List available service types",
    "inspect-service": "Inspect table metadata for a service",
    "demo-pgsql": "Seed and register a PostgreSQL demo service",
    "demo-sqlite": "Create and register a local SQLite demo service",
    "mcp-doctor": "Check bundled MCP daemon readiness",
    "mcp-config": "Print MCP client connection JSON"
  },
  "human_commands": {
    "login": "Login and print session JSON",
    "quickstart pgsql": "Register PostgreSQL, verify the API, print MCP config, and emit starter prompts",
    "pgsql connect": "Register an existing PostgreSQL database as a DreamFactory service",
    "demo pgsql": "Seed and register a PostgreSQL demo service",
    "demo sqlite": "Create and register a local SQLite smoke-test service",
    "serve --with-mcp": "Start DreamFactory and the bundled MCP daemon",
    "mcp doctor": "Check bundled MCP daemon readiness",
    "mcp config": "Print MCP client connection JSON",
    "service list-types": "List available service types",
    "service supported-types": "List quickstart-supported service types",
    "service plan": "Print a service creation payload template",
    "service apply": "Create a service from JSON",
    "service inspect": "Inspect table metadata for a service"
  }
}
JSON
      ;;
    login)
      cmd_login "$@"
      ;;
    quickstart-pgsql)
      cmd_quickstart pgsql "$@"
      ;;
    pgsql-connect)
      cmd_pgsql connect "$@"
      ;;
    plan-service)
      service_payload_template "${1:-pgsql}"
      ;;
    apply-service)
      cmd_service apply "$@"
      ;;
    supported-service-types)
      cmd_service supported-types
      ;;
    list-service-types)
      cmd_service list-types "$@"
      ;;
    inspect-service)
      cmd_service inspect "$@"
      ;;
    demo-pgsql)
      cmd_demo pgsql "$@"
      ;;
    demo-sqlite)
      cmd_demo sqlite "$@"
      ;;
    mcp-doctor)
      cmd_mcp doctor "$@"
      ;;
    mcp-config)
      cmd_mcp config "$@"
      ;;
    *)
      echo "Unknown ai command: $subcommand" >&2
      return 1
      ;;
  esac
}

# --- Main ---
case "${1:-serve}" in
  serve)
    shift 2>/dev/null || true
    cmd_serve "$@"
    ;;
  setup)
    shift
    run_setup "$@"
    ;;
  doctor)
    cmd_doctor
    ;;
  version|--version|-v)
    cmd_version
    ;;
  login)
    shift
    cmd_login "$@"
    ;;
  quickstart)
    shift
    cmd_quickstart "$@"
    ;;
  pgsql)
    shift
    cmd_pgsql "$@"
    ;;
  demo)
    shift
    cmd_demo "$@"
    ;;
  service)
    shift
    cmd_service "$@"
    ;;
  mcp)
    shift
    cmd_mcp "$@"
    ;;
  reset-admin)
    shift
    cmd_reset_admin "$@"
    ;;
  ai)
    shift
    cmd_ai "$@"
    ;;
  migrate)
    require_frankenphp
    init_storage
    $FRANKENPHP php-cli artisan migrate --force "$@"
    ;;
  artisan)
    shift
    cmd_artisan "$@"
    ;;
  help|--help|-h)
    echo "DreamFactory Quickstart — Instant governed APIs from your data"
    echo ""
    echo "Usage:"
    echo "  dreamfactory serve [--host HOST] [--port PORT] [--admin-email EMAIL] [--admin-password PASSWORD]"
    echo "  dreamfactory serve --with-mcp      Start API server and bundled MCP daemon"
    echo "  dreamfactory setup [--admin-email EMAIL] [--admin-password PASSWORD]"
    echo "  dreamfactory doctor                Check runtime readiness"
    echo "  dreamfactory mcp doctor            Check MCP bundle and daemon health"
    echo "  dreamfactory mcp serve             Start only the bundled MCP daemon"
    echo "  dreamfactory version               Print package version metadata"
    echo "  dreamfactory login                 Login and print session JSON"
    echo "  dreamfactory quickstart pgsql      Connect PostgreSQL and print next steps"
    echo "  dreamfactory pgsql connect         Register a PostgreSQL service"
    echo "  dreamfactory demo pgsql            Create and register a PostgreSQL demo"
    echo "  dreamfactory demo sqlite           Create and register a local SQLite smoke test"
    echo "  dreamfactory service supported-types List quickstart-supported service types"
    echo "  dreamfactory service list-types    List available service types"
    echo "  dreamfactory service plan TYPE     Print service payload template"
    echo "  dreamfactory service apply --file F Create a service from JSON"
    echo "  dreamfactory service inspect NAME  Inspect service table metadata"
    echo "  dreamfactory reset-admin           Create or reset the admin user"
    echo "  dreamfactory ai spec               Print AI helper capabilities"
    echo "  dreamfactory ai login              Login and print session JSON"
    echo "  dreamfactory ai quickstart-pgsql   Connect PostgreSQL and print next steps"
    echo "  dreamfactory ai pgsql-connect      Register a PostgreSQL service"
    echo "  dreamfactory ai plan-service TYPE  Print service payload template"
    echo "  dreamfactory ai apply-service --file F Create a service from JSON"
    echo "  dreamfactory ai supported-service-types List quickstart-supported service types"
    echo "  dreamfactory ai demo-pgsql         Create and register a PostgreSQL demo"
    echo "  dreamfactory ai demo-sqlite        Create and register a local SQLite smoke test"
    echo "  dreamfactory ai mcp-doctor         Check bundled MCP daemon readiness"
    echo "  dreamfactory ai mcp-config         Print MCP client connection JSON"
    echo "  dreamfactory migrate               Run database migrations"
    echo "  dreamfactory artisan [...]          Run any artisan command"
    echo ""
    echo "Environment:"
    echo "  DREAMFACTORY_STORAGE   Data directory (default: ~/.dreamfactory)"
    echo "  ADMIN_EMAIL            Admin email for first-run setup"
    echo "  ADMIN_PASSWORD         Admin password for first-run setup"
    echo "  LISTEN_HOST            Bind host (default: 0.0.0.0)"
    echo "  SERVER_PORT            Listen port (default: 8080)"
    echo "  MCP_DAEMON_PORT        MCP daemon port (default: 8006)"
    echo "  DREAMFACTORY_URL       API URL for CLI calls"
    echo "  DREAMFACTORY_SESSION_TOKEN Session token for CLI calls"
    ;;
  *)
    cmd_artisan "$@"
    ;;
esac
